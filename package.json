{
  "name": "kbo-simulation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "crawl": "node crawl-stats.mjs",
    "crawl:2025": "node crawl-stats.mjs --year 2025",
    "crawl:2026": "node crawl-stats.mjs --year 2026",
    "crawl:apply": "node crawl-stats.mjs --year 2026 --apply",
    "crawl:recent": "node crawl-recent.mjs",
    "crawl:teamrank": "node crawl-teamrank.mjs",
    "crawl:schedule": "node crawl-schedule.mjs",
    "blend": "node blend-stats.mjs",
    "predict": "node crawl-teamrank.mjs && node crawl-schedule.mjs && node crawl-recent.mjs && node blend-stats.mjs && node sim-today.mjs --log",
    "verify": "node verify-yesterday.mjs",
    "report": "node stats-report.mjs",
    "backtest:snapshot": "node predict-snapshot.mjs"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "lodash": "^4.17.21",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.1"
  }
}
