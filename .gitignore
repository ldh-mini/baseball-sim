# Dependencies
node_modules/
dist/

# Env / secrets
# .env.example은 템플릿이므로 트랙킹 (실제 키는 .env에만)
.env
.env.local
.env.*.local
!.env.example

# 인수인계용 배포 아카이브 (git archive로 재생성 가능)
*.zip

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Python (legacy generate_docx.py 등)
__pycache__/
*.pyc

# 임시 캐시 / 일별 산출물 (재생성 가능)
# schedule-today.json은 GitHub Pages 정적 fetch용으로 트랙킹
schedule-2025-*.json
schedule-2026-*.json
prediction-log.backup-*.json
prediction-log.snapshot-*.json

# 로컬 데이터 백업 보관소 (archive/data-snapshots/) — 커밋하지 않음
archive/data-snapshots/

# public/data: 빌드 시 워크플로우가 자동 생성 (root 데이터 파일을 복사)
public/data/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
